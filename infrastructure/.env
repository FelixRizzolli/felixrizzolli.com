# ============================================================
# Infrastructure
# ============================================================
ENVIRONMENT=production
NODE_ENV=production

# ============================================================
# Proxy
#
# Note: TRAEFIK_DASHBOARD_DOMAIN, ACME_EMAIL, and WITH_PROXY are
#       also managed as GitHub environment variables in CI and are
#       overridden automatically by the deploy workflow.
# ============================================================
WITH_PROXY=true
TRAEFIK_DASHBOARD_DOMAIN=traefik.example.com
ACME_EMAIL=you@example.com
# Generate with: htpasswd -nb <user> <password>
TRAEFIK_AUTH=changeme

# ============================================================
# Database (PostgreSQL)
# ============================================================
DATABASE_HOST=database
DATABASE_PORT=5432
DATABASE_USER=changeme
DATABASE_PASSWORD=changeme
DATABASE_NAMES=changeme
DATABASE_URI="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAMES}"

# ============================================================
# API — Payload CMS
#
# Note: API_DOMAIN is also managed as a GitHub environment variable
#       in CI and is overridden automatically by the deploy workflow.
# ============================================================
API_DOMAIN=api.example.com
API_HOST=0.0.0.0
API_PORT=3000
API_SECRET=changeme
CRON_SECRET=changeme
PREVIEW_SECRET=changeme
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
API_URL=https://api.example.com

# ============================================================
# WWW
#
# Note: WWW_DOMAIN is also managed as a GitHub environment variable
#       in CI and is overridden automatically by the deploy workflow.
# ============================================================
WWW_DOMAIN=example.com
WWW_HOST=0.0.0.0
WWW_PORT=3010
WWW_URL=https://example.com

# ============================================================
# Docs
#
# Note: DOCS_DOMAIN is also managed as a GitHub environment variable
#       in CI and is overridden automatically by the deploy workflow.
# ============================================================
DOCS_DOMAIN=docs.example.com
DOCS_HOST=0.0.0.0
DOCS_PORT=3020
DOCS_URL=https://docs.example.com

# ============================================================
# Wedding
#
# Note: WEDDING_DOMAIN is also managed as a GitHub environment variable
#       in CI and is overridden automatically by the deploy workflow.
# ============================================================
WEDDING_DOMAIN=wedding.example.com
WEDDING_HOST=0.0.0.0
WEDDING_PORT=3030
WEDDING_SESSION_PASSWORD=changeme
WEDDING_URL=https://wedding.example.com

# ============================================================
# Traveling
#
# Note: TRAVELING_DOMAIN is also managed as a GitHub environment variable
#       in CI and is overridden automatically by the deploy workflow.
# ============================================================
TRAVELING_DOMAIN=traveling.example.com
TRAVELING_HOST=0.0.0.0
TRAVELING_PORT=3040
TRAVELING_URL=https://traveling.example.com
